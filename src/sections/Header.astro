---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo-amvehiculos.png';
---

<div class="flex flex-col">
<section aria-hidden="true" class="relative order-2 mt-16 w-full overflow-hidden md:order-1 md:mt-0">
    <video
    src="/videos/header-amvehiculos.mp4"
    autoplay
    loop
    muted
    playsinline
    class="w-full h-[70px] object-fill md:h-[140px] md:object-cover md:object-center"
    ></video>
    <div class="absolute top-0 left-0 w-full h-full bg-background/50"></div>
</section>

<header class="order-1 flex w-full max-md:fixed max-md:inset-x-0 max-md:top-0 max-md:z-30 items-center justify-between border-b border-white/10 bg-background/90 px-3 py-2 backdrop-blur-md md:sticky md:top-0 md:z-10 md:order-2 ">
    <a href="/" class="md:hidden">
        <Image
          src={logoImg}
          alt="Logo AM Vehiculos"
          width={logoImg.width}
          height={logoImg.height}
          class="h-12 w-auto object-contain"
        />
    </a>
    <button class="md:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
    </button>
</header>
</div>